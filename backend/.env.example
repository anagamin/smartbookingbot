APP_NAME=SmartBookingBot
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Site origin only (no trailing /api). If APP_URL is https://example.com/api, set explicit *_REDIRECT_URI below.
APP_URL=http://localhost:8000

APP_TIMEZONE=Europe/Moscow

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smartbookingbot
DB_USERNAME=app
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=http://localhost:5173

GPTUNNEL_BASE_URL=https://gptunnel.ru/v1
GPTUNNEL_API_KEY=
GPTUNNEL_MODEL=gpt-4.1-mini

VK_ID_CLIENT_ID=
VK_ID_CLIENT_SECRET=
# Optional: absolute callback URL registered in VK ID. If omitted, built from APP_URL (avoids /api/api/ when APP_URL ends with /api).
# VK_ID_REDIRECT_URI=https://smartbookingbot.ru/api/oauth/vk/callback

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
# YANDEX_REDIRECT_URI=https://smartbookingbot.ru/api/oauth/yandex/callback

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

SUBSCRIPTION_PRICE_KOPECKS=100000
TRIAL_DAYS=30

VITE_APP_NAME="${APP_NAME}"
